# Copy to .env and fill in your values.
# Env vars override values from config.yaml.

DEVICE_MAC=78:ED:BC:11:42:1E
CHECK_INTERVAL=5s
FAIL_THRESHOLD=3
LOG_LEVEL=info

# --- Telegram (optional) -----------------------------------------------------
# Create a bot via @BotFather → get token.
# Find your user_id via @userinfobot.
# If TELEGRAM_BOT_TOKEN is set, TELEGRAM_ALLOWED_USER_ID must also be set —
# the agent refuses to start without a whitelist.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
